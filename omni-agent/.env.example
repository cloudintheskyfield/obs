# Omni Agent 环境变量配置示例
# 复制此文件为 .env 并根据实际情况修改配置

# VLLM 多模态服务配置
VLLM_BASE_URL=http://223.109.239.14:10002/v1/chat/completions
VLLM_API_KEY=dummy_key
VLLM_MODEL=multimodal_model

# Claude API 配置（可选）
# 如果有Claude API密钥，Agent会优先使用Claude进行某些任务
CLAUDE_API_KEY=your_claude_api_key_here

# 工作目录配置
WORK_DIR=workspace

# 安全配置
ALLOW_FILE_OPS=true
ALLOW_TERMINAL=true

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/omni_agent.log

# 网页浏览配置
WEB_HEADLESS=false
WEB_TIMEOUT=10
SCREENSHOT_DIR=screenshots

# 性能配置
REQUEST_TIMEOUT=30
MAX_RETRIES=3
MAX_HISTORY=1000

# 调试选项
DEBUG=false
VERBOSE_LOGGING=false